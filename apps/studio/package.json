{
  "name": "@redbusagent/studio",
  "version": "0.1.0",
  "private": true,
  "author": "GuileCC <guiccardoso@gmail.com>",
  "description": "Redbus Studio desktop workspace (Electron main + preload + React renderer)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder",
    "prepare:native-rebuild": "node ./scripts/prepare-native-rebuild.mjs",
    "install:app-deps": "npm run prepare:native-rebuild && electron-builder install-app-deps",
    "rebuild": "npm run prepare:native-rebuild && electron-rebuild -f -w ssh2"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@redbusagent/shared": "^0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.17.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "40.7.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
